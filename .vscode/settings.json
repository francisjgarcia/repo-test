{
  // ─── GitHub Copilot — habilitar prompt files (.github/prompts/) ───────────
  "github.copilot.chat.experimental.codeGeneration.useInstructionFiles": true,

  // Registra .github/prompts/ como fuente de comandos personalizados
  "chat.promptFiles": true,
  "chat.promptFilesLocations": {
    ".github/prompts": true
  }
}
