{
  // ─── GitHub Copilot — enable prompt files (.github/prompts/) ─────────────
  "github.copilot.chat.experimental.codeGeneration.useInstructionFiles": true,

  // Register .github/prompts/ as a source of custom slash commands
  "chat.promptFiles": true,
  "chat.promptFilesLocations": {
    ".github/prompts": true
  }
}
