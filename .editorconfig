root = true

# ── Todos los ficheros ────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ── Python ────────────────────────────────────────────────────────────
[*.py]
indent_style = space
indent_size  = 4
max_line_length = 88        # Límite de Ruff/Black

# ── YAML (docker-compose, GitHub Actions, etc.) ───────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ── JSON y TOML (pyproject.toml, package.json) ────────────────────────
[*.{json,toml}]
indent_style = space
indent_size  = 2

# ── Ficheros de entorno y config plana ───────────────────────────────
[*.{env,cfg,ini,txt}]
indent_style = space
indent_size  = 4

# ── Makefiles (obligatoriamente tabs) ────────────────────────────────
[Makefile]
indent_style = tab

# ── Markdown (los espacios al final son saltos de línea intencionales)
[*.md]
trim_trailing_whitespace = false
